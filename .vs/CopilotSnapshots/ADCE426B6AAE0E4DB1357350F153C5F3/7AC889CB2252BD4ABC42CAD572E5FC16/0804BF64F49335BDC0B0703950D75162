using Microsoft.Win32;
using application_lourde.Services;

namespace application_lourde.Examples;

/// <summary>
/// Exemple d'utilisation du ProduitImageService dans une fenêtre WPF
/// </summary>
public partial class AjouterProduitWindow : Window
{
    private readonly ProduitImageService _produitService;
    private string _cheminImageSelectionnee = string.Empty;

    public AjouterProduitWindow()
    {
        InitializeComponent();

        // Récupération de la chaîne de connexion depuis appsettings.json
        var connectionString = "Server=localhost;Port=3306;Database=epreuve_e6;User=root;Password=;";
        _produitService = new ProduitImageService(connectionString);
    }

    /// <summary>
    /// Bouton pour sélectionner une image
    /// </summary>
    private void BtnSelectionnerImage_Click(object sender, RoutedEventArgs e)
    {
        var openFileDialog = new OpenFileDialog
        {
            Title = "Sélectionner une image",
            Filter = "Images (*.jpg;*.jpeg;*.png;*.gif;*.bmp)|*.jpg;*.jpeg;*.png;*.gif;*.bmp|Tous les fichiers (*.*)|*.*",
            FilterIndex = 1
        };

        if (openFileDialog.ShowDialog() == true)
        {
            _cheminImageSelectionnee = openFileDialog.FileName;
            
            // Affichage d'un aperçu (optionnel)
            // ImagePreview.Source = new BitmapImage(new Uri(_cheminImageSelectionnee));
            
            MessageBox.Show($"Image sélectionnée : {Path.GetFileName(_cheminImageSelectionnee)}", 
                          "Succès", 
                          MessageBoxButton.OK, 
                          MessageBoxImage.Information);
        }
    }

    /// <summary>
    /// Bouton pour ajouter le produit
    /// </summary>
    private async void BtnAjouter_Click(object sender, RoutedEventArgs e)
    {
        try
        {
            // Validation des champs
            if (string.IsNullOrWhiteSpace(TxtLibelle.Text))
            {
                MessageBox.Show("Le libellé est obligatoire", "Erreur", MessageBoxButton.OK, MessageBoxImage.Warning);
                return;
            }

            if (!decimal.TryParse(TxtPrixHT.Text, out decimal prixHT) || prixHT < 0)
            {
                MessageBox.Show("Prix HT invalide", "Erreur", MessageBoxButton.OK, MessageBoxImage.Warning);
                return;
            }

            if (!decimal.TryParse(TxtTVA.Text, out decimal tva) || tva < 0)
            {
                MessageBox.Show("TVA invalide", "Erreur", MessageBoxButton.OK, MessageBoxImage.Warning);
                return;
            }

            if (!int.TryParse(TxtStock.Text, out int stock) || stock < 0)
            {
                MessageBox.Show("Stock invalide", "Erreur", MessageBoxButton.OK, MessageBoxImage.Warning);
                return;
            }

            if (string.IsNullOrWhiteSpace(_cheminImageSelectionnee))
            {
                MessageBox.Show("Veuillez sélectionner une image", "Erreur", MessageBoxButton.OK, MessageBoxImage.Warning);
                return;
            }

            // Désactivation du bouton pendant le traitement
            BtnAjouter.IsEnabled = false;
            BtnAjouter.Content = "Ajout en cours...";

            // Ajout du produit
            int produitId = await _produitService.AjouterProduitAsync(
                libelle: TxtLibelle.Text,
                description: TxtDescription.Text,
                prixHT: prixHT,
                tva: tva,
                stock: stock,
                categorie: CmbCategorie.Text,
                cheminImage: _cheminImageSelectionnee
            );

            MessageBox.Show($"Produit ajouté avec succès ! ID: {produitId}", 
                          "Succès", 
                          MessageBoxButton.OK, 
                          MessageBoxImage.Information);

            // Réinitialisation du formulaire
            ResetFormulaire();
        }
        catch (Exception ex)
        {
            MessageBox.Show($"Erreur lors de l'ajout du produit :\n{ex.Message}", 
                          "Erreur", 
                          MessageBoxButton.OK, 
                          MessageBoxImage.Error);
        }
        finally
        {
            BtnAjouter.IsEnabled = true;
            BtnAjouter.Content = "Ajouter";
        }
    }

    /// <summary>
    /// Réinitialise le formulaire
    /// </summary>
    private void ResetFormulaire()
    {
        TxtLibelle.Clear();
        TxtDescription.Clear();
        TxtPrixHT.Clear();
        TxtTVA.Text = "20.00";
        TxtStock.Clear();
        CmbCategorie.SelectedIndex = -1;
        _cheminImageSelectionnee = string.Empty;
    }
}

