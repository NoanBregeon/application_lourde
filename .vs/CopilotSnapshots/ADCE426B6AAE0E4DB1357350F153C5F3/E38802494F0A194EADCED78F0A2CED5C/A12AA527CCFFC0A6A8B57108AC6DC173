<Window x:Class="application_lourde.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:application_lourde.ViewModels"
        xmlns:views="clr-namespace:application_lourde.Views"
        Title="Gestion Drive - Stock &amp; Commandes" 
        Height="750" 
        Width="1280"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">
    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:StockViewModel}">
            <views:StockView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CommandeViewModel}">
            <views:CommandeView/>
        </DataTemplate>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Menu de navigation moderne -->
        <Border Grid.Row="0" Background="#2C3E50" Padding="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Logo et titre -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="20,15">
                    <TextBlock Text="GESTION DRIVE" 
                              FontSize="22" 
                              FontWeight="Bold" 
                              Foreground="White" 
                              VerticalAlignment="Center"/>
                    <Border Background="#0078D4" CornerRadius="3" Padding="8,4" Margin="15,0,0,0">
                        <TextBlock Text="PRO" FontSize="12" FontWeight="Bold" Foreground="White"/>
                    </Border>
                </StackPanel>
                
                <!-- Boutons de navigation -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="20,10">
                    <Button Content="Stock &amp; Produits" 
                           Command="{Binding NavigateToStockCommand}"
                           Width="180"
                           Height="45"
                           Margin="5"
                           Background="#34495E"
                           FontSize="14"
                           FontWeight="SemiBold">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#34495E"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" 
                                                   CornerRadius="5"
                                                   Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#0078D4"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    
                    <Button Content="Preparation Commandes" 
                           Command="{Binding NavigateToCommandesCommand}"
                           Width="200"
                           Height="45"
                           Margin="5"
                           Background="#34495E"
                           FontSize="14"
                           FontWeight="SemiBold">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#34495E"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" 
                                                   CornerRadius="5"
                                                   Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#107C10"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Contenu principal avec ombre -->
        <Border Grid.Row="1" Background="#F5F5F5" Padding="0">
            <ContentControl Content="{Binding CurrentView}" Margin="0"/>
        </Border>
        
        <!-- Pied de page -->
        <Border Grid.Row="2" Background="#34495E" Padding="15,10">
            <Grid>
                <TextBlock Text="Application de Gestion Drive - Version 1.0" 
                          FontSize="11" 
                          Foreground="#BDC3C7" 
                          HorizontalAlignment="Left"
                          VerticalAlignment="Center"/>
                <TextBlock Text=".NET 8 WPF - MVVM Architecture" 
                          FontSize="11" 
                          Foreground="#BDC3C7" 
                          HorizontalAlignment="Right"
                          VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
