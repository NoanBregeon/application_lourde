-- Mise à jour des totaux des commandes
UPDATE commandes c
SET total_ht = (
    SELECT COALESCE(SUM(lc.quantite_demandee * lc.prix_unitaire_ht), 0)
    FROM lignes_commande lc
    WHERE lc.commande_id = c.id
),
total_ttc = (
    SELECT COALESCE(SUM(lc.quantite_demandee * lc.prix_unitaire_ht * (1 + p.taux_tva / 100)), 0)
    FROM lignes_commande lc
    JOIN produits p ON lc.produit_id = p.id
    WHERE lc.commande_id = c.id
);

